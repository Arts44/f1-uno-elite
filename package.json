{
  "type": "module",
  "scripts": {
    "build": "esbuild app.js --bundle --format=iife --outfile=app.bundle.js --global-name=F1App --minify --sourcemap",
    "dev": "esbuild app.js --bundle --format=iife --outfile=app.bundle.js --global-name=F1App --sourcemap --watch",
    "test": "node --test \"tests/*.test.js\"",
    "test:watch": "node --test --watch \"tests/*.test.js\""
  },
  "devDependencies": {
    "esbuild": "^0.28.1"
  }
}
